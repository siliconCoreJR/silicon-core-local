# Normalize line endings: store LF in git, checkout as-is on all platforms
* text=auto eol=lf

# Explicitly binary — never touch line endings
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.glb binary
*.gltf binary
*.zip binary
*.pdf binary
